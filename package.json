    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "telegraf": "^4.16.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
